# AgentQuest Algorand facilitator (fork) environment
# Copy to .env and fill values for your deployed facilitator service.

PORT=4022

# Algorand network + RPC used by facilitator
# localnet | testnet | mainnet
ALGORAND_NETWORK=testnet
ALGORAND_RPC_URL=https://testnet-api.algonode.cloud
# Optional API token for providers that require auth.
ALGORAND_RPC_TOKEN=

# Facilitator signer credentials (choose one approach)
FACILITATOR_MNEMONIC="replace with facilitator 25-word mnemonic"
# FACILITATOR_PRIVATE_KEY_BASE64=replace-with-base64-encoded-private-key

# Split-payment policy defaults (must match world quote semantics)
# Testnet USDC ASA by default
FACILITATOR_ASSET_ID=10458941
# Counterparty recipient for testing. In production marketplace flows this should
# be the listing owner's agent wallet address, provided dynamically per quote.
FACILITATOR_COUNTERPARTY_PAY_TO=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
FACILITATOR_PLATFORM_PAY_TO=BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB
FACILITATOR_PLATFORM_FEE_BPS=500

# Quote binding checks
FACILITATOR_ENFORCE_SPLIT=true
FACILITATOR_ENFORCE_QUOTE_EXPIRY=true
FACILITATOR_ENFORCE_QUOTE_NONCE=true

# Optional: when set, facilitator emits proofHeader in /settle responses
# using this secret (for trusted middleware->world forwarding).
FACILITATOR_PROOF_SHARED_SECRET=replace-with-same-secret-as-world-caddy
